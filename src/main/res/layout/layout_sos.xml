<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══ HEADER BANNER ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:gravity="center">

            <!-- Pulsing SOS icon circle -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Outer glow ring -->
                <View
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/circle_pulse"
                    android:alpha="0.2"/>

                <!-- Red circle -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="36dp"
                    app:cardBackgroundColor="#FEE2E2"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/ic_sos"
                        app:tint="#DC2626"
                        android:layout_gravity="center"/>
                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency SOS"
                android:textColor="#0F172A"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap any number to call instantly"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- ═══ CALL BUTTONS ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="0dp">

            <!-- 🚨 National Emergency  112 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sosCall112"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FECACA"
                app:cardBackgroundColor="#FEF2F2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardCornerRadius="16dp"
                        app:cardBackgroundColor="#FCA5A5"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚨"
                            android:textSize="28sp"
                            android:layout_gravity="center"/>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NATIONAL EMERGENCY"
                            android:textColor="#991B1B"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="112"
                            android:textColor="#7F1D1D"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="0dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All Emergencies"
                            android:textColor="#DC2626"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_cool_call"
                        app:tint="#DC2626"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row: Police + Ambulance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- 🚓 Police  100 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sosCall100"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E7FF"
                    app:cardBackgroundColor="#F5F8FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚓"
                            android:textSize="32sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100"
                            android:textColor="#312E81"
                            android:textSize="30sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Police"
                            android:textColor="#4F46E5"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="14dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#E0E7FF"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Now"
                                android:textColor="#4F46E5"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 🚑 Ambulance  108 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sosCall108"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#D1FAE5"
                    app:cardBackgroundColor="#F0FDF4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚑"
                            android:textSize="32sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="108"
                            android:textColor="#064E3B"
                            android:textSize="30sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ambulance"
                            android:textColor="#059669"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="14dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#D1FAE5"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Now"
                                android:textColor="#059669"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Row: Fire + Disaster -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- 🚒 Fire Brigade  101 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sosCall101"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FFEDD5"
                    app:cardBackgroundColor="#FFF7ED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚒"
                            android:textSize="32sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="101"
                            android:textColor="#7C2D12"
                            android:textSize="30sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fire Brigade"
                            android:textColor="#EA580C"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="14dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#FFEDD5"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Now"
                                android:textColor="#EA580C"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 🛡️ NDRF  1078 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sosCall1078"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0F2FE"
                    app:cardBackgroundColor="#F0F9FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡️"
                            android:textSize="32sp"
                            android:layout_marginBottom="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1078"
                            android:textColor="#0C4A6E"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NDRF Helpline"
                            android:textColor="#0284C7"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="14dp"
                            app:cardCornerRadius="10dp"
                            app:cardBackgroundColor="#E0F2FE"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Call Now"
                                android:textColor="#0284C7"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ═══ IMPORTANT NOTE ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FECACA"
                app:cardBackgroundColor="#FEF2F2">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="22sp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Only use in genuine emergencies. False calls are a criminal offence."
                        android:textColor="#B91C1C"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
