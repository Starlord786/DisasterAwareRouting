<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aurora_wide"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Pulse ring — centered to icon, no clipping parent so it can expand freely -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_pulse"
        app:layout_constraintTop_toTopOf="@id/splashIcon"
        app:layout_constraintBottom_toBottomOf="@id/splashIcon"
        app:layout_constraintStart_toStartOf="@id/splashIcon"
        app:layout_constraintEnd_toEndOf="@id/splashIcon"/>

    <!-- App logo icon -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/ic_app_logo"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/splashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>

    <!-- "Disaster Aware" -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disaster Aware"
        android:textColor="#4F46E5"
        android:textSize="18sp"
        android:letterSpacing="0.06"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/splashIcon"
        app:layout_constraintBottom_toTopOf="@id/splashRoutePlanning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- "Route Planning" -->
    <TextView
        android:id="@+id/splashRoutePlanning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Route Planning"
        android:textColor="#0F172A"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/splashTitle"
        app:layout_constraintBottom_toTopOf="@id/splashSafetyLine"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- "for Disaster Safety" -->
    <TextView
        android:id="@+id/splashSafetyLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="for Disaster Safety"
        android:textColor="#4F46E5"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.01"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/splashRoutePlanning"
        app:layout_constraintBottom_toTopOf="@id/splashSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/splashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Navigating to Safety."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/splashSafetyLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
