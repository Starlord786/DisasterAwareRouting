<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- A radar/pulse circle behind the icon -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_pulse"
        app:layout_constraintTop_toTopOf="@id/splashIcon"
        app:layout_constraintBottom_toBottomOf="@id/splashIcon"
        app:layout_constraintStart_toStartOf="@id/splashIcon"
        app:layout_constraintEnd_toEndOf="@id/splashIcon"/>

    <!-- Disaster/Warning Icon -->
    <ImageView
        android:id="@+id/splashIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_pathguard_shield"
        app:layout_constraintBottom_toTopOf="@id/splashTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="24dp"/>

    <!-- App Title -->
    <TextView
        android:id="@+id/splashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PathGuard"
        android:textColor="#0F172A"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashIcon" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/splashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Navigating to Safety."
        android:textColor="#64748B"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/splashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
