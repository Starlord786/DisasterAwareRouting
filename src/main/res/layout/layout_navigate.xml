<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─────────── Premium Header ─────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/navHeaderArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="48dp"
                    android:paddingBottom="20dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="#00FFFFFF">

                    <!-- Logo -->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_app_logo"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disaster Aware"
                        android:textColor="#4F46E5"
                        android:textSize="14sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Navigation Hub"
                        android:textColor="#0F172A"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weather · Map · Emergency SOS"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </FrameLayout>

            <!-- ─────────── Cards Area ─────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- ═══════════ WEATHER CARD ═══════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/weatherCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <!-- Weather icon bubble -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="18dp"
                            app:cardBackgroundColor="#E0F2FE"
                            app:cardElevation="0dp">
                            <TextView
                                android:id="@+id/weatherIconText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⛅"
                                android:textSize="30sp"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Current Weather"
                                android:textColor="#64748B"
                                android:textSize="12sp"
                                android:letterSpacing="0.05"/>

                            <TextView
                                android:id="@+id/weatherTitleText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loading..."
                                android:textColor="#0F172A"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>

                            <TextView
                                android:id="@+id/weatherDescText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fetching conditions..."
                                android:textColor="#64748B"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- Right arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌡️"
                            android:textSize="22sp"
                            android:layout_marginStart="8dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════ MAP CARD ═══════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/openMapButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#4F46E5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="22dp"
                        android:gravity="center_vertical">

                        <!-- Map icon bubble -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="18dp"
                            app:cardBackgroundColor="#6366F1"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_cool_map"
                                app:tint="#FFFFFF"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="18dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIVE TRACKER"
                                android:textColor="#A5B4FC"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Open Map"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Danger zones · Safe routes"
                                android:textColor="#C7D2FE"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#FFFFFF"
                            android:textSize="36sp"
                            android:layout_marginStart="8dp"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══════════ SOS HINT STRIP ═══════════ -->

                <!-- ═══════════ AVAILABLE RESOURCES ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available Resources"
                        android:textColor="#0F172A"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find available aid and supplies near you."
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Location Error banner -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/locationErrorBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#FCA5A5"
                        app:cardBackgroundColor="#FEF2F2">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️"
                                android:textSize="18sp"
                                android:layout_marginEnd="12dp"/>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Location Error"
                                    android:textColor="#991B1B"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Location permission denied. Showing all resources."
                                    android:textColor="#B91C1C"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Resource 1: Community Center Shelter -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardShelter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <!-- Icon bubble -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#F1F5F9"
                                app:cardElevation="0dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏢"
                                    android:textSize="30sp"
                                    android:layout_gravity="center"/>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="SHELTER"
                                    android:textColor="#3B82F6"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.1"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Community Center"
                                    android:textColor="#0F172A"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Open 24/7 · 150 beds"
                                    android:textColor="#64748B"
                                    android:textSize="13sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#CBD5E1"
                                android:textSize="36sp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Resource 2: Water Distribution Point -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardWater"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <!-- Icon bubble -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#F0FDF4"
                                app:cardElevation="0dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💧"
                                    android:textSize="30sp"
                                    android:layout_gravity="center"/>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="WATER"
                                    android:textColor="#10B981"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.1"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Distribution Point"
                                    android:textColor="#0F172A"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bottled · 500 gal"
                                    android:textColor="#64748B"
                                    android:textSize="13sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#CBD5E1"
                                android:textSize="36sp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Resource 3: Mobile First Aid Station -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFirstAid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <!-- Icon bubble -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#FEF2F2"
                                app:cardElevation="0dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏥"
                                    android:textSize="30sp"
                                    android:layout_gravity="center"/>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="FIRST AID"
                                    android:textColor="#EF4444"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.1"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mobile Station"
                                    android:textColor="#0F172A"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Immediate aid · Resp."
                                    android:textColor="#64748B"
                                    android:textSize="13sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#CBD5E1"
                                android:textSize="36sp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Resource 4: Emergency Food Bank -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFoodBank"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E2E8F0"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <!-- Icon bubble -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#FFFBEB"
                                app:cardElevation="0dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🍲"
                                    android:textSize="30sp"
                                    android:layout_gravity="center"/>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="FOOD"
                                    android:textColor="#F59E0B"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.1"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Emergency Bank"
                                    android:textColor="#0F172A"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Non-perishable · 2 tons"
                                    android:textColor="#64748B"
                                    android:textSize="13sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#CBD5E1"
                                android:textSize="36sp"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

